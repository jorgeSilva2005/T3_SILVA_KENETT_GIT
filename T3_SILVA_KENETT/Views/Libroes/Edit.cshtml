@model T3_SILVA_KENETT.Models.Libro

@{
    ViewData["Title"] = "Editar Libro";
}

<div class="container mt-4">

    <div class="card shadow-lg border-0">

        <div class="card-header bg-warning text-dark">
            <h2 class="mb-0">✏️ Editar Libro</h2>
            <p class="mb-0">Modifica los datos del libro seleccionado</p>
        </div>

        <div class="card-body">

            <form asp-action="Edit">

                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <input type="hidden" asp-for="Id" />

                <div class="row">

                    <div class="col-md-6 mb-3">
                        <label asp-for="Titulo" class="form-label fw-bold">Título</label>
                        <input asp-for="Titulo" class="form-control" placeholder="Ingrese el título del libro" />
                        <span asp-validation-for="Titulo" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Autor" class="form-label fw-bold">Autor</label>
                        <input asp-for="Autor" class="form-control" placeholder="Ingrese el autor" />
                        <span asp-validation-for="Autor" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Tema" class="form-label fw-bold">Tema</label>
                        <input asp-for="Tema" class="form-control" placeholder="Ingrese el tema" />
                        <span asp-validation-for="Tema" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Editorial" class="form-label fw-bold">Editorial</label>
                        <input asp-for="Editorial" class="form-control" placeholder="Ingrese la editorial" />
                        <span asp-validation-for="Editorial" class="text-danger"></span>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label asp-for="AnioPublicacion" class="form-label fw-bold">Año de Publicación</label>
                        <input asp-for="AnioPublicacion" class="form-control" placeholder="Ejemplo: 2024" />
                        <span asp-validation-for="AnioPublicacion" class="text-danger"></span>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label asp-for="Paginas" class="form-label fw-bold">Páginas</label>
                        <input asp-for="Paginas" class="form-control" placeholder="Entre 10 y 1000" />
                        <span asp-validation-for="Paginas" class="text-danger"></span>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label asp-for="Copias" class="form-label fw-bold">Copias</label>
                        <input asp-for="Copias" class="form-control" placeholder="Entre 1 y 20" />
                        <span asp-validation-for="Copias" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Categoria" class="form-label fw-bold">Categoría</label>
                        <input asp-for="Categoria" class="form-control" placeholder="Ejemplo: Novela, Ciencia, Historia" />
                        <span asp-validation-for="Categoria" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Material" class="form-label fw-bold">Material</label>
                        <input asp-for="Material" class="form-control" placeholder="Ejemplo: Físico, Digital" />
                        <span asp-validation-for="Material" class="text-danger"></span>
                    </div>

                </div>

                <div class="mt-3">
                    <button type="submit" class="btn btn-warning fw-bold">
                        💾 Guardar Cambios
                    </button>

                    <a asp-action="Index" class="btn btn-secondary">
                        ← Volver al Listado
                    </a>
                </div>

            </form>

        </div>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
