@{
    ViewData["Title"] = "Libros de Diseño de Software";
}

<div class="container mt-4">

    <div class="text-center mb-4">
        <h1 class="text-success fw-bold">🎨 Libros de Diseño de Software</h1>
        <p class="lead">Información, descripciones y videos sobre libros relacionados con diseño de software.</p>
    </div>

    <div class="row">

        <div class="col-md-4 mb-4">
            <div class="card shadow h-100">
                <img src="https://placehold.co/600x350?text=Design+Patterns" class="card-img-top" />
                <div class="card-body">
                    <h5 class="card-title">Design Patterns</h5>
                    <p class="card-text">
                        Libro clásico sobre patrones de diseño. Ayuda a resolver problemas comunes en el desarrollo
                        de software usando soluciones reutilizables.
                    </p>
                    <iframe width="100%" height="200" src="https://www.youtube.com/embed/tAuRQs_d9F8" allowfullscreen></iframe>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card shadow h-100">
                <img src="https://placehold.co/600x350?text=Refactoring" class="card-img-top" />
                <div class="card-body">
                    <h5 class="card-title">Refactoring</h5>
                    <p class="card-text">
                        Libro que enseña cómo mejorar el código existente sin cambiar su funcionamiento,
                        haciéndolo más limpio y fácil de mantener.
                    </p>
                    <iframe width="100%" height="200" src="https://www.youtube.com/embed/vqEg37e4Mkw" allowfullscreen></iframe>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card shadow h-100">
                <img src="https://placehold.co/600x350?text=Head+First+Design+Patterns" class="card-img-top" />
                <div class="card-body">
                    <h5 class="card-title">Head First Design Patterns</h5>
                    <p class="card-text">
                        Libro que explica patrones de diseño de forma sencilla y visual, ideal para comprender
                        buenas prácticas en el diseño de software.
                    </p>
                    <iframe width="100%" height="200" src="https://www.youtube.com/embed/GCraGHx6gso" allowfullscreen></iframe>
                </div>
            </div>
        </div>

    </div>

</div>