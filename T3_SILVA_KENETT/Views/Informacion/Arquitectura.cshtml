@{
    ViewData["Title"] = "Libros de Arquitectura de Software";
}

<div class="container mt-4">

    <div class="text-center mb-4">
        <h1 class="text-primary fw-bold">🏗️ Libros de Arquitectura de Software</h1>
        <p class="lead">Información, descripciones y videos sobre libros relacionados con arquitectura de software.</p>
    </div>

    <div class="row">

        <div class="col-md-4 mb-4">
            <div class="card shadow h-100">
                <img src="https://placehold.co/600x350?text=Clean+Architecture" class="card-img-top" />
                <div class="card-body">
                    <h5 class="card-title">Clean Architecture</h5>
                    <p class="card-text">
                        Libro que explica cómo organizar el código de una aplicación para que sea mantenible,
                        flexible y fácil de modificar con el tiempo.
                    </p>
                    <iframe width="100%" height="200" src="https://www.youtube.com/embed/Nltqi7ODZTM" allowfullscreen></iframe>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card shadow h-100">
                <img src="https://placehold.co/600x350?text=Software+Architecture" class="card-img-top" />
                <div class="card-body">
                    <h5 class="card-title">Software Architecture in Practice</h5>
                    <p class="card-text">
                        Libro enfocado en la arquitectura de sistemas, calidad del software, diseño de componentes
                        y toma de decisiones técnicas.
                    </p>
                    <iframe width="100%" height="200" src="https://www.youtube.com/embed/4E1BHTvhB7Y" allowfullscreen></iframe>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card shadow h-100">
                <img src="https://placehold.co/600x350?text=Enterprise+Architecture" class="card-img-top" />
                <div class="card-body">
                    <h5 class="card-title">Patterns of Enterprise Application Architecture</h5>
                    <p class="card-text">
                        Libro que presenta patrones utilizados en aplicaciones empresariales, ayudando a construir
                        sistemas más ordenados y escalables.
                    </p>
                    <iframe width="100%" height="200" src="https://www.youtube.com/embed/zzMLg3Ys5vI" allowfullscreen></iframe>
                </div>
            </div>
        </div>

    </div>

</div>